# Terraform
# NOTE: .terraform.lock.hcl is committed on purpose (HashiCorp best practice):
# it pins provider versions+hashes so every checkout/CI uses the same binaries.
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfvars
*.tfstate
!terraform/*.tfvars.example

# Ansible
ansible/*.retry

# Kubernetes
kubeconfig
*.kubeconfig

# Packer
packer/**/*.pkrvars.hcl

# Secrets
*.pem
*.key
.env
certs/
